# Architect Runner MVP — Environment Variables Example

#

# Copy this file to:

# .env.local

#

# Do not commit .env.local.

# Do not expose server-only secrets in browser code.

# ------------------------------------------------------------

# App

# ------------------------------------------------------------

ARCHITECT_APP_NAME="Architect Runner MVP"
ARCHITECT_APP_URL="http://localhost:3000"
ARCHITECT_ENV="development"

# ------------------------------------------------------------

# Supabase — Public Browser Variables

# ------------------------------------------------------------

# These can be used in the Next.js browser client.

# The anon key is public, but RLS must protect all data.

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ------------------------------------------------------------

# Supabase — Server Only

# ------------------------------------------------------------

# Never expose this in client components.

# Never prefix this with NEXT_PUBLIC_.

# Use only in server-side code, route handlers, or controlled backend functions.

SUPABASE_SERVICE_ROLE_KEY=""

# ------------------------------------------------------------

# Runner Pairing / Machine Auth

# ------------------------------------------------------------

# Used by backend code for token hashing/signing if needed.

# Generate a strong random value before real use.

ARCHITECT_MACHINE_TOKEN_SECRET=""

# Pairing token expiry in minutes.

ARCHITECT_PAIRING_TOKEN_EXPIRY_MINUTES="20"

# ------------------------------------------------------------

# Runner Defaults

# ------------------------------------------------------------

ARCHITECT_RUNNER_VERSION="0.1.0"
ARCHITECT_RUNNER_POLL_INTERVAL_MS="5000"
ARCHITECT_RUNNER_HEARTBEAT_INTERVAL_MS="15000"
ARCHITECT_RUNNER_OFFLINE_THRESHOLD_SECONDS="90"

# ------------------------------------------------------------

# Safety Defaults

# ------------------------------------------------------------

ARCHITECT_MAX_LOG_MESSAGE_CHARS="10000"
ARCHITECT_MAX_COMMAND_OUTPUT_CHARS="20000"

# Set to false in MVP.

# Architect Runner MVP should not allow arbitrary remote shell commands.

ARCHITECT_ENABLE_ARBITRARY_COMMANDS="false"

# Set to false in MVP.

# Production deployments should be blocked.

ARCHITECT_ENABLE_PRODUCTION_DEPLOYMENTS="false"

# Set to false in MVP.

# Database reset/destructive operations should be blocked.

ARCHITECT_ENABLE_DATABASE_RESET="false"

# ------------------------------------------------------------

# Optional Future AI Variables

# ------------------------------------------------------------

# Not required for MVP.

# Do not use these until OpenAI CTO/team lead agents are implemented.

OPENAI_API_KEY=""

# Future only. Not used in MVP.

ANTHROPIC_API_KEY=""

# Future only. Not used in MVP.

GITHUB_TOKEN=""

# Future only. Not used in MVP.

VERCEL_TOKEN=""

# ------------------------------------------------------------

# Local Development Notes

# ------------------------------------------------------------

# Required for Phase 0:

# - NEXT_PUBLIC_SUPABASE_URL

# - NEXT_PUBLIC_SUPABASE_ANON_KEY

#

# Required for serious backend work:

# - SUPABASE_SERVICE_ROLE_KEY

# - ARCHITECT_MACHINE_TOKEN_SECRET

#

# Never upload .env.local contents into Architect logs.

# Runner must redact secrets before sending logs to the backend.
